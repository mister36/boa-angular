{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "apps",
  "projects": {
    "digital-banking-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "apps/digital-banking-app",
      "sourceRoot": "apps/digital-banking-app/src",
      "prefix": "boa",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/digital-banking-app",
            "index": "apps/digital-banking-app/src/index.html",
            "main": "apps/digital-banking-app/src/main.ts",
            "polyfills": "apps/digital-banking-app/src/polyfills.ts",
            "tsConfig": "apps/digital-banking-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "apps/digital-banking-app/src/favicon.ico",
              "apps/digital-banking-app/src/assets"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "libs/boa-design-system/src/lib/styles"
              ]
            },
            "styles": [
              "libs/boa-design-system/src/lib/styles/styles.scss",
              "apps/digital-banking-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "apps/digital-banking-app/src/environments/environment.ts",
                  "with": "apps/digital-banking-app/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "digital-banking-app:build:production"
            },
            "development": {
              "browserTarget": "digital-banking-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "digital-banking-app:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "apps/digital-banking-app/src/test.ts",
            "polyfills": "apps/digital-banking-app/src/polyfills.ts",
            "tsConfig": "apps/digital-banking-app/tsconfig.spec.json",
            "karmaConfig": "apps/digital-banking-app/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "stylePreprocessorOptions": {
              "includePaths": [
                "libs/boa-design-system/src/lib/styles"
              ]
            },
            "assets": [
              "apps/digital-banking-app/src/favicon.ico",
              "apps/digital-banking-app/src/assets"
            ],
            "styles": [
              "libs/boa-design-system/src/lib/styles/styles.scss",
              "apps/digital-banking-app/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
